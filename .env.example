# Copy to .env and fill in. Never commit .env.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
PINECONE_API_KEY=
PINECONE_INDEX=mf-faq-chunks
PINECONE_NAMESPACE=mf-faq-active
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
# PINECONE_HOST=https://faq-chatbot-xxxx.svc.<env>.pinecone.io
# Full ingestion: delete all vectors in this namespace before upsert (default on).
# Set to 0/false only for local experiments against a shared namespace.
PINECONE_REPLACE_NAMESPACE=1
EMBEDDING_MODEL=llama-text-embed-v2
PLAYWRIGHT=0
